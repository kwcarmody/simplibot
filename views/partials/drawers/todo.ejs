<div class="drawer-shell <%= (selectedTodo || isNewTodo) ? 'open' : '' %>">
  <div class="drawer-header">
    <div>
      <div class="surface-label"><%= isNewTodo ? 'New ToDo' : 'ToDo Details' %></div>
      <h2><%= isNewTodo ? 'New ToDo' : (selectedTodo?.title || 'ToDo Details') %></h2>
    </div>
    <a class="drawer-close" href="/todos" aria-label="Close drawer">×</a>
  </div>

  <% if (selectedTodo || isNewTodo) { %>
    <form method="post" action="/todos/save">
      <input type="hidden" name="todoId" value="<%= selectedTodo?.id || '' %>" />

      <div class="surface-card">
        <div class="surface-label">Title</div>
        <input type="text" name="title" value="<%= selectedTodo?.title || '' %>" placeholder="Enter todo title" required />
      </div>

      <div class="surface-card">
        <div class="surface-label">Status</div>
        <select name="status">
          <% ['ToDo','Working','Blocked','Done','Archived'].forEach((statusOption) => { %>
            <option value="<%= statusOption %>" <%= (selectedTodo?.status || 'ToDo') === statusOption ? 'selected' : '' %>><%= statusOption %></option>
          <% }) %>
        </select>
      </div>

      <div class="surface-card">
        <div class="surface-label">Due Date</div>
        <input type="datetime-local" name="dueDate" value="<%= selectedTodo?.dueDateInput || '' %>" />
      </div>

      <div class="surface-card">
        <div class="surface-label">Owner Type</div>
        <select name="ownerType">
          <option value="user" <%= (selectedTodo?.ownerType || 'user') === 'user' ? 'selected' : '' %>>user</option>
          <option value="bot" <%= selectedTodo?.ownerType === 'bot' ? 'selected' : '' %>>bot</option>
        </select>
      </div>

      <div class="surface-card">
        <div class="surface-label">Owner User ID</div>
        <input type="text" name="ownerUser" value="<%= selectedTodo?.ownerUser || '' %>" placeholder="Defaults to current user" />
      </div>

      <div class="surface-card">
        <div class="surface-label">Owner Label</div>
        <input type="text" name="ownerLabel" value="<%= selectedTodo?.ownerLabel || '' %>" placeholder="Used for bot/system owners" />
      </div>

      <div class="surface-card">
        <div class="surface-label">Details</div>
        <textarea name="details" rows="6" placeholder="Add details"><%= selectedTodo?.details || '' %></textarea>
      </div>

      <div class="drawer-actions">
        <button class="btn btn-primary" type="submit"><%= isNewTodo ? 'Create ToDo' : 'Save Changes' %></button>
        <a class="btn btn-secondary" href="/todos">Cancel</a>
      </div>
    </form>
  <% } else { %>
    <div class="empty-state">
      <p>Select a ToDo to view details, or click the plus button to create a new one.</p>
    </div>
  <% } %>
</div>
