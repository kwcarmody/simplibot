<div class="drawer-header">
  <div class="d-flex align-items-start justify-content-between gap-3">
      <div class="drawer-header-inner-content">
          <div class="drawer-header-global">
            <div class="muted-label label">ToDos</div>
            <a class="btn btn-sm btn-secondary-global control" href="/todos">Close</a>
          </div>
          <h2 class="h4 mt-2 mb-1"><%= isNewTodo ? 'New ToDo' : (selectedTodo?.title || 'ToDo Details') %></h2>
          <div class="text-secondary small">Manage ToDos</div>
      </div>
  </div>
</div>
<div class="drawer-body mt-4">
  <form class="todo-flyout__body" method="post" action="/todos/save">
    <% if (!isNewTodo && selectedTodo?.id) { %>
      <input type="hidden" name="todoId" value="<%= selectedTodo.id %>" />
    <% } %>

    <!--Title-->
    <div class="settings-stack mb-3">
        <div class="w-100">
            <label class="form-label">Title</label>
            <input id="todo-title" class="form-control" name="title" value="<%= selectedTodo?.title || '' %>" placeholder="Enter todo title" required  />
        </div>
    </div>

    <!--Status-->
    <div class="settings-stack mb-3">
        <div class="w-100">
            <label class="form-label">Status</label>
            <select class="form-select" id="todo-status" name="status">
              <% ['ToDo','Working','Blocked','Done','Archived'].forEach((statusOption) => { %>
                <option value="<%= statusOption %>" <%= (selectedTodo?.status || 'ToDo') === statusOption ? 'selected' : '' %>><%= statusOption %></option>
              <% }) %>
            </select>
        </div>
    </div>

    <!--Due Date-->
    <div class="settings-stack mb-3">
        <div class="w-100">
            <label class="form-label">Due Date</label>
            <input id="todo-dueDate" type="datetime-local" name="dueDate" class="form-control" value="<%= selectedTodo?.dueDateInput || '' %>" />
        </div>
    </div>

    <input type="hidden" name="ownerType" value="user" />

    <!--Owner User-->
    <div class="settings-stack mb-3">
        <div class="w-100">
            <label class="form-label">Owner</label>
            <input type="hidden" name="ownerUser" value="<%= selectedTodo?.ownerUser || '' %>" />
            <select
              id="todo-ownerUser"
              class="form-select"
              disabled
            >
              <% (tenant?.users || []).forEach((user) => { %>
                <option
                  value="<%= user.id %>"
                  <%= (selectedTodo?.ownerUser || '') === user.id ? 'selected' : '' %>
                >
                  <%= user.name || user.email || '' %>
                </option>
              <% }) %>
            </select>
        </div>
    </div>

    <!--Details-->
    <div class="settings-stack mb-3">
        <div class="w-100">
            <label class="form-label">Details</label>
            <textarea id="todo-details" class="form-control" name="details" rows="6"><%= selectedTodo?.details || '' %></textarea>
        </div>
    </div>

    <button class="btn secondary btn-light w-100" type="submit"><%= isNewTodo ? 'Create ToDo' : 'Save Changes' %></button>

  </form>
</div>
