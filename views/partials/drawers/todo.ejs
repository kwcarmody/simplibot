<div class="todo-flyout__header">
  <div>
    <p class="todo-flyout__eyebrow"><%= isNewTodo ? 'New ToDo' : 'ToDo Details' %></p>
    <h2 class="todo-flyout__title"><%= isNewTodo ? 'New ToDo' : (selectedTodo?.title || 'ToDo Details') %></h2>
  </div>
  <a class="todo-flyout__close" href="/todos" aria-label="Close ToDo flyout">×</a>
</div>

<form class="todo-flyout__body" method="post" action="/todos/save">
  <input type="hidden" name="todoId" value="<%= selectedTodo?.id || '' %>" />

  <div class="todo-flyout__section">
    <label class="todo-flyout__label" for="todo-title">Title</label>
    <input id="todo-title" class="todo-flyout__input" type="text" name="title" value="<%= selectedTodo?.title || '' %>" placeholder="Enter todo title" required />
  </div>

  <div class="todo-flyout__grid">
    <div class="todo-flyout__section">
      <label class="todo-flyout__label" for="todo-status">Status</label>
      <select id="todo-status" class="todo-flyout__input" name="status">
        <% ['ToDo','Working','Blocked','Done','Archived'].forEach((statusOption) => { %>
          <option value="<%= statusOption %>" <%= (selectedTodo?.status || 'ToDo') === statusOption ? 'selected' : '' %>><%= statusOption %></option>
        <% }) %>
      </select>
    </div>

    <div class="todo-flyout__section">
      <label class="todo-flyout__label" for="todo-dueDate">Due Date</label>
      <input id="todo-dueDate" class="todo-flyout__input" type="datetime-local" name="dueDate" value="<%= selectedTodo?.dueDateInput || '' %>" />
    </div>
  </div>

  <div class="todo-flyout__grid">
    <div class="todo-flyout__section">
      <label class="todo-flyout__label" for="todo-ownerType">Owner Type</label>
      <select id="todo-ownerType" class="todo-flyout__input" name="ownerType">
        <option value="user" <%= (selectedTodo?.ownerType || 'user') === 'user' ? 'selected' : '' %>>user</option>
        <option value="bot" <%= selectedTodo?.ownerType === 'bot' ? 'selected' : '' %>>bot</option>
      </select>
    </div>

    <div class="todo-flyout__section">
      <label class="todo-flyout__label" for="todo-ownerUser">Owner User ID</label>
      <input id="todo-ownerUser" class="todo-flyout__input" type="text" name="ownerUser" value="<%= selectedTodo?.ownerUser || '' %>" />
    </div>
  </div>

  <div class="todo-flyout__section">
    <label class="todo-flyout__label" for="todo-ownerLabel">Owner Label</label>
    <input id="todo-ownerLabel" class="todo-flyout__input" type="text" name="ownerLabel" value="<%= selectedTodo?.ownerLabel || '' %>" />
  </div>

  <div class="todo-flyout__section">
    <label class="todo-flyout__label" for="todo-details">Details</label>
    <textarea id="todo-details" class="todo-flyout__input todo-flyout__textarea" name="details" rows="6"><%= selectedTodo?.details || '' %></textarea>
  </div>

  <div class="todo-flyout__footer">
    <button class="btn btn-primary" type="submit"><%= isNewTodo ? 'Create ToDo' : 'Save Changes' %></button>
    <a class="btn btn-secondary" href="/todos">Cancel</a>
  </div>
</form>
